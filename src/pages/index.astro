          </div>
        </div>
      </section>


      <section id="certifications" aria-labelledby="cert-title" data-reveal>
        <div class="wrap">
          <div class="section-head">
            <div>
              <div class="eyebrow"><span class="dot" aria-hidden="true"></span>CONTINUOUS LEARNING</div>
              <h2 id="cert-title">Certifications & Training.</h2>
            </div>
          </div>
          <div class="grid grid-3">
